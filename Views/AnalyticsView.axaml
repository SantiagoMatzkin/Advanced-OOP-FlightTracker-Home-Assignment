<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             x:Class="FlightTracker.Views.AnalyticsView">
    <Border Padding="12"
            Background="#111827"
            BorderBrush="#1F2937"
            BorderThickness="1"
            CornerRadius="8">
        <ScrollViewer>
            <StackPanel Spacing="10">
                <Grid ColumnDefinitions="1.25*,1.25*,1.25*,Auto"
                      ColumnSpacing="10">
                    <StackPanel Spacing="6">
                        <TextBlock Foreground="#F9FAFB"
                                   Text="Departure Date" />
                        <DatePicker SelectedDate="{Binding Filters.DepartureDate}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Spacing="6">
                        <TextBlock Foreground="#F9FAFB"
                                   Text="Aircraft" />
                        <ComboBox ItemsSource="{Binding AircraftFilters}"
                                  SelectedItem="{Binding Filters.AircraftFilter}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Spacing="6">
                        <TextBlock Foreground="#F9FAFB"
                                   Text="Status" />
                        <ComboBox ItemsSource="{Binding StatusFilters}"
                                  SelectedItem="{Binding Filters.StatusFilter}" />
                    </StackPanel>

                    <Button Grid.Column="3"
                            VerticalAlignment="Bottom"
                            Command="{Binding ExportAnalyticsCommand}"
                            Content="Export Analytics (JSON)" />
                </Grid>

                <StackPanel Orientation="Horizontal"
                            Spacing="8">
                    <Button Command="{Binding ToggleStatusChartCommand}"
                            Content="{Binding StatusChartButtonText}" />
                    <Button Command="{Binding ToggleAircraftChartCommand}"
                            Content="{Binding AircraftChartButtonText}" />
                    <Button Command="{Binding ToggleHourlyChartCommand}"
                            Content="{Binding HourlyChartButtonText}" />
                    <TextBlock VerticalAlignment="Center"
                               Foreground="#CBD5E1"
                               Text="{Binding AnalyticsExportMessage}" />
                </StackPanel>

                <TextBlock Foreground="#CBD5E1"
                           Text="The charts below update from LINQ projections over the active date, aircraft, and status filters." />

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="10">
                    <Border Grid.Column="0"
                            Padding="8"
                            Background="#1F2937"
                            BorderBrush="#334155"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel Spacing="8">
                            <TextBlock Foreground="#F9FAFB"
                                       FontWeight="SemiBold"
                                       Text="Top Airlines by Traffic Volume" />
                            <lvc:CartesianChart Height="250"
                                                Series="{Binding AirlineSeries}"
                                                XAxes="{Binding AirlineXAxes}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Padding="8"
                            Background="#1F2937"
                            BorderBrush="#334155"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel Spacing="8">
                            <TextBlock Foreground="#F9FAFB"
                                       FontWeight="SemiBold"
                                       Text="Busiest Route per Time of Day" />
                            <lvc:CartesianChart Height="250"
                                                Series="{Binding TimeOfDayRouteSeries}"
                                                XAxes="{Binding TimeOfDayXAxes}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Padding="8"
                        Background="#1F2937"
                        BorderBrush="#334155"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Foreground="#F9FAFB"
                                   FontWeight="SemiBold"
                                   Text="Country-Level Traffic Trends" />
                        <lvc:PieChart Height="250"
                                      Series="{Binding CountryTrafficSeries}" />
                    </StackPanel>
                </Border>

                <Border IsVisible="{Binding ShowStatusChart}"
                        Padding="8"
                        Background="#1F2937"
                        BorderBrush="#334155"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Foreground="#F9FAFB"
                                   FontWeight="SemiBold"
                                   Text="Status Breakdown" />
                        <lvc:PieChart Height="220"
                                      Series="{Binding StatusBreakdownSeries}" />
                    </StackPanel>
                </Border>

                <Border IsVisible="{Binding ShowAircraftChart}"
                        Padding="8"
                        Background="#1F2937"
                        BorderBrush="#334155"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Foreground="#F9FAFB"
                                   FontWeight="SemiBold"
                                   Text="Aircraft Usage" />
                        <lvc:CartesianChart Height="220"
                                            Series="{Binding AircraftUsageSeries}"
                                            XAxes="{Binding AircraftUsageXAxes}" />
                    </StackPanel>
                </Border>

                <Border IsVisible="{Binding ShowHourlyChart}"
                        Padding="8"
                        Background="#1F2937"
                        BorderBrush="#334155"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Foreground="#F9FAFB"
                                   FontWeight="SemiBold"
                                   Text="Departure Hour Pattern" />
                        <lvc:CartesianChart Height="220"
                                            Series="{Binding DepartureHourSeries}"
                                            XAxes="{Binding DepartureHourXAxes}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
